{
  "manifest_version": 3,
  "name": "Block YouTube Link Previews",
  "version": "2.0",
  "update_url": "https://bcs-dfisher.github.io/blockGooglePreviewBubble/block-google-preview-bubble/update.xml",
  "description": "Removes the link preview bubble element for YouTube videos on *.google.com",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Block YouTube Link Previews"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.google.com/*"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_start"
    }
  ]
}
